<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - Learn Free Quran</title>

    <link rel="icon" type="image/x-icon" href="~/favicon.ico" />

    <!-- Site / Vendor CSS -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/Content/css/site.css" />
    <link rel="stylesheet" href="~/Content/sweetalert.css" asp-append-version="true" />

    <style>
        .modal-custom {
            display: none;
            position: fixed;
            z-index: 1050;
            padding-top: 100px;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            overflow: auto;
            background-color: rgba(0, 0, 0, 0.4);
        }

        .modal-custom-content {
            background-color: #fefefe;
            margin: auto;
            padding: 20px;
            border: 3px solid #7b3d00;
            width: 30%;
        }

        .modal-custom-close {
            color: #aaaaaa;
            float: right;
            font-size: 28px;
            font-weight: bold;
        }

            .modal-custom-close:hover,
            .modal-custom-close:focus {
                color: #000;
                text-decoration: none;
                cursor: pointer;
            }
    </style>

    @RenderSection("Styles", required: false)
</head>
<body class="homepage">
    <!-- Modal -->
    <div id="myModal" class="modal-custom">
        <div class="modal-custom-content">
            <span class="modal-custom-close">&times;</span>
            <h5 class="text-center" id="modelheading"></h5>
            <p class="text-dark" id="modelparagraph"></p>
        </div>
    </div>

    <div id="page-wrapper">
        <!-- Header -->
        <div id="header-wrapper">
            <header id="header" class="container">
                <!-- Logo -->
                <div id="logo" style="text-align: center;">
                    <a asp-controller="Home" asp-action="Index" target="_blank">
                        <img src="~/images/logo.png" alt="Learn Free Quran Logo" style="height: 50px;" asp-append-version="true" />
                    </a>
                </div>

                <!-- Nav -->
                <nav id="nav">
                    <ul>
                        <li class="current"><a asp-controller="Admin" asp-action="GetAllStudents">All Students</a></li>
                        <li><a asp-controller="Admin" asp-action="GetScheduledStudents">Scheduled</a></li>
                        <li><a asp-controller="Admin" asp-action="GetUnscheduledStudents">Unscheduled</a></li>
                        <li><a asp-controller="Admin" asp-action="GetTodaySchedule">Today Schedule</a></li>
                        <li><a asp-controller="Admin" asp-action="GetContactUs">Contact</a></li>
                        <li>
                            <a href="#">Forum</a>
                            <ul id="sublst">
                                <li><a asp-controller="Admin" asp-action="ForumMainPage"><b>All Questions</b></a></li>
                                <li><a asp-controller="Admin" asp-action="Publish"><b>Publish</b></a></li>
                                <li><a asp-controller="Admin" asp-action="UnPublish"><b>UnPublish</b></a></li>
                            </ul>
                        </li>
                        <li><a asp-controller="Admin" asp-action="AddBook">Add Book</a></li>
                        <li><a asp-controller="Admin" asp-action="GetAllBooks">All Books</a></li>
                        <li><a asp-controller="Admin" asp-action="GetFeedback">Feedback</a></li>
                    </ul>
                    <a asp-controller="Admin" asp-action="Logout" style="float: right;">Logout</a>
                </nav>
            </header>
        </div>

        <main role="main">
            @RenderBody()
        </main>

        <!-- Footer -->
        <hr style="border-top: solid 1px #c60; width: 1200px;" />
        <div id="footer-wrapper">
            <footer id="footer" class="container">
                <div class="row">
                    <div class="col-12">
                        <div id="copyright">
                            <ul class="menu">
                                <li>&copy; @DateTime.Now.Year Learn Free Quran | All rights reserved.</li>
                            </ul>
                        </div>
                    </div>
                </div>
            </footer>
        </div>
    </div>

    <!-- Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script src="~/Scripts/sweetalert.min.js" asp-append-version="true"></script>
    <script src="~/Scripts/Forum.js" asp-append-version="true"></script>

    <script src="~/assets/js/jquery.dropotron.min.js" asp-append-version="true"></script>
    <script src="~/assets/js/skel.min.js" asp-append-version="true"></script>
    <script src="~/assets/js/util.js" asp-append-version="true"></script>
    <script src="~/assets/js/main.js" asp-append-version="true"></script>

    @RenderSection("Scripts", required: false)
</body>
</html>